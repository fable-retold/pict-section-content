{
	"name": "pict-section-content",
	"version": "0.0.9",
	"description": "Pict content rendering section - markdown parsing, Mermaid diagrams, and KaTeX equations",
	"main": "source/Pict-Section-Content.js",
	"scripts": {
		"start": "node source/Pict-Section-Content.js",
		"test": "npx quack test",
		"tests": "npx quack test -g",
		"coverage": "npx quack coverage",
		"build": "npx quack build"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/stevenvelozo/pict-section-content.git"
	},
	"author": "steven velozo <steven@velozo.com>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/stevenvelozo/pict-section-content/issues"
	},
	"homepage": "https://github.com/stevenvelozo/pict-section-content#readme",
	"dependencies": {
		"pict-provider": "^1.0.12",
		"pict-section-code": "^1.0.3",
		"pict-view": "^1.0.67"
	},
	"devDependencies": {
		"pict": "^1.0.350",
		"quackage": "^1.0.59"
	},
	"mocha": {
		"diff": true,
		"extension": [
			"js"
		],
		"package": "./package.json",
		"reporter": "spec",
		"slow": "75",
		"timeout": "5000",
		"ui": "tdd",
		"watch-files": [
			"source/**/*.js",
			"test/**/*.js"
		],
		"watch-ignore": [
			"lib/vendor"
		]
	}
}
